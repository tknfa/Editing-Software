# Translated with gpt-4.1-mini
#: ../effects.rst:1008
msgid ""
"``(float, 0 to 10)`` Blur radius in pixels at 720p (auto-scaled to clip size)"
msgstr ""
"``(float, 0 إلى 10)`` نصف قطر التمويه بالبكسل عند 720p (مقياس تلقائي حسب حجم "
"المقطع)"

# Translated with gpt-4.1-mini
