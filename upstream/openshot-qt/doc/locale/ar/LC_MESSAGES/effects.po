msgid "amount"
msgstr "الكمية"

# Translated with gpt-4.1-mini
#: ../effects.rst:1007
msgid "``(float, 0 to 40)`` Strength multiplier / up to 100% edge boost"
msgstr "``(float, 0 إلى 40)`` مضاعف القوة / حتى 100% تعزيز الحواف"

# Translated with gpt-4.1-mini
