msgid "``(float, 0 to 1)`` Minimum luma difference that will be sharpened"
msgstr "``(float, 0 إلى 1)`` الحد الأدنى لفارق اللمعان الذي سيتم توضيحه"

# Translated with gpt-4.1-mini
#: ../effects.rst:1010
msgid "mode"
msgstr "الوضع"

# Translated with gpt-4.1-mini
