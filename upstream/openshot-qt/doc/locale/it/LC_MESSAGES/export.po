# Translated with gpt-4.1-mini
#: ../export.rst:74
msgid "Start at First Clip"
msgstr "Inizia dalla Prima Clip"

# Translated with gpt-4.1-mini
#: ../export.rst:74
msgid ""
"This checkbox will toggle the **Start Frame** between `0.0` and the `start` "
"of the first clip/transition position."
msgstr ""
"Questa casella di controllo commuta il **Frame Iniziale** tra `0.0` e "
