# Translated with gpt-4.1-mini
#: ../effects.rst:375
msgid "bleed"
msgstr "bleed"

# Translated with gpt-4.1-mini
#: ../effects.rst:375
msgid ""
"``(float, 0–1)`` **Chroma bleed / fringing.** Horizontal chroma shift + blur "
"with a slight desaturation. Gives the “rainbow edge” look."
msgstr ""
"``(float, 0–1)`` **Chảy màu chroma / viền màu.** Dịch chuyển chroma ngang + "
