# Translated with gpt-4.1-mini
#: ../effects.rst:380
msgid "seed_offset"
msgstr "seed_offset"

# Translated with gpt-4.1-mini
#: ../effects.rst:380
msgid ""
"``(int, 0–1000)`` Adds to the internal seed (derived from the effect ID) for "
"deterministic variation between clips."
msgstr ""
"``(int, 0–1000)`` Thêm vào hạt giống nội bộ (lấy từ ID hiệu ứng) để tạo biến "
"thể xác định giữa các clip."

# Translated with gpt-4.1-mini
