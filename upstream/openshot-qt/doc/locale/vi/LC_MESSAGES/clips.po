# Translated with gpt-4.1-mini
#: ../clips.rst:506
msgid "Darken"
msgstr "Làm tối"

# Translated with gpt-4.1-mini
#: ../clips.rst:506
msgid "Chooses the darker pixel from the two layers, per channel."
msgstr "Chọn điểm ảnh tối hơn trong hai lớp, theo từng kênh."

# Translated with gpt-4.1-mini
#: ../clips.rst:507
msgid "Multiply"
