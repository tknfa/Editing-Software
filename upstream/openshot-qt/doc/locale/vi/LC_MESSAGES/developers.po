# Translated with gpt-4.1-mini
#: ../developers.rst:55
msgid "Getting the Latest Source Code"
msgstr "Lấy mã nguồn mới nhất"

# Translated with gpt-4.1-mini
#: ../developers.rst:56
msgid ""
"Before we can fix any bugs or add any features, we need to get the source "
"code onto your computer."
msgstr ""
"Trước khi sửa lỗi hoặc thêm tính năng, chúng ta cần lấy mã nguồn về máy tính "
"của bạn."

# Translated with gpt-4.1-mini
