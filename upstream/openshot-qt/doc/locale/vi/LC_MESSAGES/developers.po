msgid ""
":libopenshot-wiki:`Windows Build Instructions <Windows-Build-Instructions>`"
msgstr ""
":libopenshot-wiki:`Hướng dẫn xây dựng Windows <Windows-Build-Instructions>`"

# Translated with gpt-4.1-mini
