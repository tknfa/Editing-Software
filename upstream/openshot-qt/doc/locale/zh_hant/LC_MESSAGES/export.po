# Translated with gpt-4.1-mini
#: ../export.rst:72
msgid "The first frame to export (default is 1)"
msgstr "匯出的第一幀（預設為 1）"

# Translated with gpt-4.1-mini
#: ../export.rst:73
msgid "End Frame"
msgstr "結束幀"

# Translated with gpt-4.1-mini
#: ../export.rst:73
msgid ""
