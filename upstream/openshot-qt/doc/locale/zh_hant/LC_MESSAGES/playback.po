msgstr "請確認您正在執行最新的 OpenShot 每日版本：https://www.openshot.org/download#daily"

# Translated with gpt-4.1-mini
#: ../playback.rst:100
msgid "Clean Install"
msgstr "全新安裝"

# Translated with gpt-4.1-mini
#: ../playback.rst:100
msgid "See :ref:`preferences_reset_ref` for a clean install"
