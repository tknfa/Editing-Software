# Translated with gpt-4.1-mini
#: ../export.rst:99
msgid "Width"
msgstr "Szerokość"

# Translated with gpt-4.1-mini
#: ../export.rst:99
msgid "The width of the video export (in pixels)"
msgstr "Szerokość eksportowanego wideo (w pikselach)"

# Translated with gpt-4.1-mini
#: ../export.rst:100
msgid "Height"
msgstr "Wysokość"

# Translated with gpt-4.1-mini
#: ../export.rst:100
