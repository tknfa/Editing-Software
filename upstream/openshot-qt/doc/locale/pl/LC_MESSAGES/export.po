msgstr "Ustawienia sekwencji obrazów"

# Translated with gpt-4.1-mini
#: ../export.rst:117
msgid "Image Setting Name"
msgstr "Nazwa ustawienia obrazu"

# Translated with gpt-4.1-mini
#: ../export.rst:119
msgid "Image Format"
