# Translated with gpt-4.1-mini
#: ../export.rst:119
msgid ""
"The string format that represents the output file name in a sequence of "
"images. For example, %05d.png would pad a number with 5 digits: 00001.png, "
"00002.png."
msgstr ""
"Format tekstowy reprezentujący nazwę pliku wyjściowego w sekwencji obrazów. "
"Na przykład %05d.png wypełni numer do 5 cyfr: 00001.png, 00002.png."

