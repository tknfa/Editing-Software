# Translated with gpt-4.1-mini
#: ../timeline.rst:74
msgid "Selection is one of the most important timeline skills:"
msgstr "Wybór jest jedną z najważniejszych umiejętności na osi czasu:"

# Translated with gpt-4.1-mini
#: ../timeline.rst:76
msgid "Click an item to select it."
msgstr "Kliknij element, aby go wybrać."

# Translated with gpt-4.1-mini
#: ../timeline.rst:77
msgid ":kbd:`Ctrl+Click` adds or removes items from selection."
msgstr ":kbd:`Ctrl+Klik` dodaje lub usuwa elementy z zaznaczenia."

# Translated with gpt-4.1-mini
#: ../timeline.rst:78
msgid ""
":kbd:`Shift+Click` selects a range between your anchor item and the clicked "
"item."
msgstr ""
":kbd:`Shift+Klik` zaznacza zakres między elementem kotwicznym a klikniętym "
"elementem."

# Translated with gpt-4.1-mini
#: ../timeline.rst:79
msgid ":kbd:`Ctrl+Shift+Click` adds that range to your current selection."
msgstr ":kbd:`Ctrl+Shift+Klik` dodaje ten zakres do bieżącego zaznaczenia."

# Translated with gpt-4.1-mini
#: ../timeline.rst:80
msgid ""
":kbd:`Alt+Click` ripple-selects from the clicked item to the end of the "
"track."
msgstr ""
":kbd:`Alt+Klik` zaznacza falowo od klikniętego elementu do końca ścieżki."

# Translated with gpt-4.1-mini
#: ../timeline.rst:81
