# Translated with gpt-4.1-mini
#: ../export.rst:119
msgid "Image Format"
msgstr "Myndaform"

# Translated with gpt-4.1-mini
#: ../export.rst:119
msgid ""
"The string format that represents the output file name in a sequence of "
"images. For example, %05d.png would pad a number with 5 digits: 00001.png, "
"00002.png."
msgstr ""
"Strengjaforskrift sem táknar nafn útfluttrar skráar í röð mynda. Til dæmis "
"myndi %05d.png bæta við tölustöfum þannig að númerið verði 5 stafa: 00001."
"png, 00002.png."

