msgstr ""
"``(float, 0 til 10)`` Magn til að margfalda bylgjuna (gera hana stærri)"

# Translated with gpt-4.1-mini
#: ../effects.rst:1166
msgid "shift_x"
msgstr "færa_x"

# Translated with gpt-4.1-mini
