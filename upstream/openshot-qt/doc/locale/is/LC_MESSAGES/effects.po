msgstr "``(float, -180 til 180)`` Snúningur um framás (gráður)."

# Translated with gpt-4.1-mini
#: ../effects.rst:1050
msgid "fov"
msgstr "fov"

# Translated with gpt-4.1-mini
#: ../effects.rst:1050
msgid ""
"``(float, 0 to 179)`` **Out FOV.** Horizontal field of view of the virtual "
