# Translated with gpt-4.1-mini
#: ../effects.rst:68
msgid "Animated mask videos can be looped."
msgstr "Hreyfimynduð grímumyndbönd má spila í lykkju."

# Translated with gpt-4.1-mini
#: ../effects.rst:69
msgid ""
"When looping, set start/end mask trim carefully. If not adjusted, OpenShot "
"loops the entire mask source, not just the segment you intended to repeat."
msgstr ""
"Þegar spilað er í lykkju, stilltu byrjun og enda grímuskurð vandlega. Ef "
"ekki er stillt, spilar OpenShot alla grímuuppsprettuna í lykkju, ekki bara "
"þann hluta sem þú ætlaðir að endurtaka."

