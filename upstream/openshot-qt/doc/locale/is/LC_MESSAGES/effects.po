msgstr ""
"``(float, 0–1)`` **Tracking-stripe.** Lyftir neðri borða, bætir við hvísli/"
"hávaða þar og víkkar svæðið sem lyft er eftir því sem gildið hækkar."

# Translated with gpt-4.1-mini
#: ../effects.rst:379
msgid "static_bands"
msgstr "static_bands"

# Translated with gpt-4.1-mini
#: ../effects.rst:379
msgid ""
