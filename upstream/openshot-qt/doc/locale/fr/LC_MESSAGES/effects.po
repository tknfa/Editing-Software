msgid "speed_y"
msgstr "vitesse_y"

# Translated with gpt-4.1-mini
#: ../effects.rst:1167
msgid "``(float, 0 to 300)`` Speed of the wave on the Y-axis"
msgstr "``(float, 0 à 300)`` Vitesse de la vague sur l'axe Y"

# Translated with gpt-4.1-mini
#: ../effects.rst:1168
msgid "wavelength"
msgstr "longueur_d'onde"

# Translated with gpt-4.1-mini
#: ../effects.rst:1168
