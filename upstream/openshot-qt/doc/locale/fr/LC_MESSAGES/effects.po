# Translated with gpt-4.1-mini
#: ../effects.rst:58
msgid "Choose a mask source (static image or animated mask video)."
msgstr ""
"Choisissez une source de masque (image statique ou vidéo de masque animée)."

# Translated with gpt-4.1-mini
#: ../effects.rst:59
msgid ""
"Adjust :guilabel:`Mask Mode` (for example, *Limit to Mask* or *Vary "
"Strength*)."
