# Translated with gpt-4.1-mini
#: ../effects.rst:68
msgid "Animated mask videos can be looped."
msgstr "Les vidéos de masques animés peuvent être bouclées."

# Translated with gpt-4.1-mini
#: ../effects.rst:69
msgid ""
"When looping, set start/end mask trim carefully. If not adjusted, OpenShot "
"loops the entire mask source, not just the segment you intended to repeat."
msgstr ""
"Lors du bouclage, réglez soigneusement le découpage de début/fin du masque. "
"Sinon, OpenShot boucle toute la source du masque, pas seulement le segment "
"que vous souhaitez répéter."

