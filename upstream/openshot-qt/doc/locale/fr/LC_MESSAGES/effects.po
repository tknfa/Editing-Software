msgstr "Pour ajuster une propriété :"

# Translated with gpt-4.1-mini
#: ../effects.rst:74
msgid "Drag the slider for coarse changes."
msgstr "Faites glisser le curseur pour des modifications grossières."

# Translated with gpt-4.1-mini
#: ../effects.rst:75
msgid "Double-click to enter precise values."
msgstr "Double-cliquez pour saisir des valeurs précises."

# Translated with gpt-4.1-mini
