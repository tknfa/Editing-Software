# Translated with gpt-4.1-mini
#: ../contributing.rst:22
msgid "Contributing"
msgstr "Contribuyendo"

# Translated with gpt-4.1-mini
#: ../contributing.rst:24
msgid ""
"Want to help improve OpenShot (*and make some friends in the process*)? "
"Please consider joining our open-source team by filling out this quick "
"`contributor form <https://forms.gle/CRqkS5tLMJE1V36V8>`_ and introduce "
"yourself! All volunteers are welcome, regardless of skills or skill level. "
"**Let's build something amazing!**"
msgstr ""
"¿Quieres ayudar a mejorar OpenShot (*y hacer algunos amigos en el proceso*)? "
"Por favor, considera unirte a nuestro equipo de código abierto llenando este "
"rápido `formulario de contribuyente <https://forms.gle/CRqkS5tLMJE1V36V8>`_ "
"y preséntate. Todos los voluntarios son bienvenidos, sin importar "
"habilidades o nivel. **¡Construyamos algo increíble!**"

