# Translated with gpt-4.1-mini
#: ../animation.rst:68
msgid ""
"Interpolated values are calculated linear (each step value is equal). Icon: :"
"guilabel:`Diamond`."
msgstr ""
"Los valores interpolados se calculan linealmente (cada valor de paso es "
"igual). Icono: :guilabel:`Diamante`."

# Translated with gpt-4.1-mini
#: ../animation.rst:69
msgid "Constant"
msgstr "Constante"

# Translated with gpt-4.1-mini
#: ../animation.rst:69
msgid ""
"Interpolated values stay the same until the next key frame, and jump to the "
"new value. Icon: :guilabel:`Square`."
msgstr ""
"Los valores interpolados permanecen iguales hasta el siguiente fotograma "
"clave y saltan al nuevo valor. Icono: :guilabel:`Cuadrado`."

