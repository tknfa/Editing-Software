msgstr "Povlačenjem plavih kvadrata mijenja se **veličina** slike."

# Translated with gpt-4.1-mini
#: ../clips.rst:321
msgid "Dragging the center will move the **location** of the image."
msgstr "Povlačenjem središta pomiče se **položaj** slike."

# Translated with gpt-4.1-mini
#: ../clips.rst:322
