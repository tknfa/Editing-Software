# Translated with gpt-4.1-mini
#: ../preferences.rst:150
msgid ""
"Autosave is a feature in OpenShot which automatically saves the current "
"changes to your project after a specific number of minutes, helping to "
"reduce the risk or impact of data loss in case of a crash, freeze or user "
"error."
msgstr ""
"Automatsko spremanje je značajka u OpenShotu koja automatski sprema trenutne "
"promjene na vašem projektu nakon određenog broja minuta, pomažući smanjiti "
"rizik ili posljedice gubitka podataka u slučaju pada, zamrzavanja ili "
"korisničke pogreške."

# Translated with gpt-4.1-mini
#: ../preferences.rst:160
msgid "Enable Autosave"
msgstr "Omogući automatsko spremanje"

# Translated with gpt-4.1-mini
#: ../preferences.rst:161
msgid "Autosave Interval (minutes)"
msgstr "Interval automatskog spremanja (minute)"

# Translated with gpt-4.1-mini
#: ../preferences.rst:161
msgid "3"
msgstr "3"

# Translated with gpt-4.1-mini
#: ../preferences.rst:162
msgid "History Limit (# of undo/redo)"
msgstr "Ograničenje povijesti (broj poništavanja/ponavljanja)"

# Translated with gpt-4.1-mini
#: ../preferences.rst:162
msgid "15"
msgstr "15"

# Translated with gpt-4.1-mini
#: ../preferences.rst:163
msgid "Recovery Limit (# of project copies)"
msgstr "Ograničenje oporavka (broj kopija projekta)"

# Translated with gpt-4.1-mini
