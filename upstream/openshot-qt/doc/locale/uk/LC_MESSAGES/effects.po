"розмиття на піксель. 3 ітерації = Гаусове розмиття."

# Translated with gpt-4.1-mini
#: ../effects.rst:442
msgid "sigma"
msgstr "сигма"

# Translated with gpt-4.1-mini
#: ../effects.rst:442
