#: ../effects.rst:1165
msgid "multiplier"
msgstr "множник"

# Translated with gpt-4.1-mini
#: ../effects.rst:1165
msgid "``(float, 0 to 10)`` Amount to multiply the wave (make it bigger)"
msgstr "``(float, 0 to 10)`` Коефіцієнт збільшення хвилі"

# Translated with gpt-4.1-mini
#: ../effects.rst:1166
msgid "shift_x"
msgstr "зсув_x"

# Translated with gpt-4.1-mini
#: ../effects.rst:1166
msgid "``(float, 0 to 1000)`` Amount to shift X-axis"
msgstr "``(float, 0 to 1000)`` Величина зсуву по осі X"

# Translated with gpt-4.1-mini
#: ../effects.rst:1167
msgid "speed_y"
msgstr "швидкість_y"

# Translated with gpt-4.1-mini
#: ../effects.rst:1167
msgid "``(float, 0 to 300)`` Speed of the wave on the Y-axis"
msgstr "``(float, 0 to 300)`` Швидкість хвилі по осі Y"

# Translated with gpt-4.1-mini
#: ../effects.rst:1168
msgid "wavelength"
msgstr "довжина хвилі"

# Translated with gpt-4.1-mini
#: ../effects.rst:1168
