msgid "reader"
msgstr "читач"

# Translated with gpt-4.1-mini
#: ../effects.rst:405
msgid ""
"``(reader)`` This reader can use any image or video as input for your "
"grayscale wipe"
msgstr ""
"``(reader)`` Цей читач може використовувати будь-яке зображення або відео як "
