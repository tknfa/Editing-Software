# Translated with gpt-4.1-mini
#: ../contributing.rst:41
msgid "`User Community <https://openshot.org/forum>`_"
msgstr "`Спільнота користувачів <https://openshot.org/forum>`_"

# Translated with gpt-4.1-mini
#: ../contributing.rst:42
