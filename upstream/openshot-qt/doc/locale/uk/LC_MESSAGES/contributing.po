# Translated with gpt-4.1-mini
#: ../contributing.rst:37
msgid "Customer Service"
msgstr "Обслуговування клієнтів"

# Translated with gpt-4.1-mini
#: ../contributing.rst:38
msgid "Social Media / Marketing"
msgstr "Соціальні мережі / Маркетинг"

# Translated with gpt-4.1-mini
#: ../contributing.rst:39
msgid "`Software Development <https://github.com/OpenShot>`_"
msgstr "`Розробка програмного забезпечення <https://github.com/OpenShot>`_"

# Translated with gpt-4.1-mini
#: ../contributing.rst:40
msgid "Art / Design / UI"
