# Translated with gpt-4.1-mini
#: ../animation.rst:90
msgid ""
":guilabel:`Ping-Pong` alternates direction (forward then backward, etc.)."
msgstr ""
":guilabel:`Ping-Pong` wechselt die Richtung ab (vorwärts, dann rückwärts "
