# Translated with gpt-4.1-mini
#: ../export.rst:72
msgid "Start Frame"
msgstr "Startbild"

# Translated with gpt-4.1-mini
#: ../export.rst:72
msgid "The first frame to export (default is 1)"
msgstr "Das erste zu exportierende Bild (Standard ist 1)"

# Translated with gpt-4.1-mini
#: ../export.rst:73
msgid "End Frame"
msgstr "Endbild"

# Translated with gpt-4.1-mini
#: ../export.rst:73
msgid ""
"The final frame to export (default is the last frame in your project to "
"contain a clip)"
msgstr ""
