# Translated with gpt-4.1-mini
#: ../clips.rst:511
msgid "Color Dodge"
msgstr "Evitare culoare"

# Translated with gpt-4.1-mini
#: ../clips.rst:511
msgid "Brightens highlights strongly; can blow out to white."
msgstr "Lumineză puternic zonele luminoase; poate duce la alb complet."

# Translated with gpt-4.1-mini
#: ../clips.rst:512
msgid "Add"
msgstr "Adăugare"

# Translated with gpt-4.1-mini
#: ../clips.rst:512
msgid ""
"Adds pixel values. Strong brightening; clips at white. Also called *Linear "
