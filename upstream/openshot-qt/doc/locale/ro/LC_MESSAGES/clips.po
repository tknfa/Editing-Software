#: ../clips.rst:507
msgid "Multiply"
msgstr "Înmulțire"

# Translated with gpt-4.1-mini
#: ../clips.rst:507
msgid "Multiplies colors. Darkens and helps textures sit on top of footage."
msgstr ""
"Înmulțește culorile. Întunecă și ajută texturile să stea peste materialul "
