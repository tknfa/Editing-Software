# Translated with gpt-4.1-mini
#: ../clips.rst:508
msgid "Color Burn"
msgstr "Ardere culoare"

# Translated with gpt-4.1-mini
#: ../clips.rst:508
msgid "Pushes shadows darker and boosts contrast; can clip to black."
msgstr "Întunecă umbrele și crește contrastul; poate tăia la negru."

# Translated with gpt-4.1-mini
#: ../clips.rst:509
msgid "Lighten"
msgstr "Luminozitate"

# Translated with gpt-4.1-mini
#: ../clips.rst:509
msgid "Chooses the lighter pixel from the two layers, per channel."
msgstr "Alege pixelul mai deschis dintre cele două straturi, pe canal."

