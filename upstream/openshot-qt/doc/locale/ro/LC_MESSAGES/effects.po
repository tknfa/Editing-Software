# Translated with gpt-4.1-mini
#: ../effects.rst:57
msgid "Open the effect :guilabel:`Properties`."
msgstr "Deschide :guilabel:`Proprietățile` efectului."

# Translated with gpt-4.1-mini
#: ../effects.rst:58
msgid "Choose a mask source (static image or animated mask video)."
msgstr "Alege o sursă de mască (imagine statică sau video cu mască animată)."

# Translated with gpt-4.1-mini
#: ../effects.rst:59
msgid ""
"Adjust :guilabel:`Mask Mode` (for example, *Limit to Mask* or *Vary "
"Strength*)."
