# Translated with gpt-4.1-mini
#: ../effects.rst:57
msgid "Open the effect :guilabel:`Properties`."
msgstr "Avaa efektin :guilabel:`Ominaisuudet`."

# Translated with gpt-4.1-mini
#: ../effects.rst:58
msgid "Choose a mask source (static image or animated mask video)."
msgstr "Valitse maskin lähde (staattinen kuva tai animoitu maskivideo)."

# Translated with gpt-4.1-mini
#: ../effects.rst:59
msgid ""
"Adjust :guilabel:`Mask Mode` (for example, *Limit to Mask* or *Vary "
