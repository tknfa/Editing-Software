<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE openshot-export-option>
<export-option>
	<type translatable="True">All Formats</type>
	<title translatable="True">MOV (h.264)</title>
	<videoformat>mov</videoformat>
	<videocodec>libx264</videocodec>
	<audiocodec>aac</audiocodec>
	<audiochannels>2</audiochannels>
	<audiochannellayout>3</audiochannellayout>
	<videobitrate
	 low="30 crf"
	 med="23 crf"
	 high="20 crf"></videobitrate>
	<audiobitrate
	 low="96 kb/s"
	 med="128 kb/s"
	 high="160 kb/s"></audiobitrate>
	<samplerate>48000</samplerate>
</export-option>
