<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE openshot-export-option>
<export-option>
	<type translatable="True">All Formats</type>
    <title translatable="True">MOV (mpeg4)</title>
	<videoformat>mov</videoformat>
	<videocodec>mpeg4</videocodec>
	<audiocodec>libmp3lame</audiocodec>
	<audiochannels>2</audiochannels>
	<audiochannellayout>3</audiochannellayout>
	<videobitrate
	 low="1 Mb/s"
	 med="3 Mb/s"
	 high="8 Mb/s"></videobitrate>
	<audiobitrate
	 low="96 kb/s"
	 med="128 kb/s"
	 high="160 kb/s"></audiobitrate>
	<samplerate>48000</samplerate>
</export-option>
