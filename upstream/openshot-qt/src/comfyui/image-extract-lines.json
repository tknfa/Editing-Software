{
  "action_icon": "ai-action-extract-lines.svg",
  "menu_category": "enhance",
  "menu_order": 53,
  "menu_parent": "extract",
  "name": "Lines",
  "open_dialog": false,
  "output_type": "image",
  "template_id": "image-extract-lines",
  "workflow": {
    "1": {
      "class_type": "LoadImage",
      "inputs": {
